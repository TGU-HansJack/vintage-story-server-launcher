<UserControl
    x:Class="VSSL.Ui.Views.ModView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:VSSL.Ui.ViewModels"
    x:Name="ModRoot"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="vm:ModViewModel"
    mc:Ignorable="d"
    >
    <Design.DataContext>
        <vm:ModViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,Auto,*" RowSpacing="10">
        <Border Grid.Row="0" Padding="12" CornerRadius="8" BorderBrush="Gray" BorderThickness="1">
            <Grid ColumnDefinitions="2.1*,2.8*,Auto,Auto" ColumnSpacing="8">
                <ComboBox Grid.Column="0" ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBox
                    Grid.Column="1"
                    Text="{Binding ModZipPath, UpdateSourceTrigger=PropertyChanged}"
                    Watermark="输入 Mod ZIP 路径（例如 C:\mods\example.zip）"
                    />

                <Button Grid.Column="2" Width="90" Command="{Binding ImportByPathCommand}" Content="导入" />
                <Button Grid.Column="3" Width="90" Command="{Binding RefreshCommand}" Content="刷新" />
            </Grid>
        </Border>

        <TextBlock Grid.Row="1" Text="{Binding StatusMessage}" TextWrapping="Wrap" />

        <Grid Grid.Row="2" RowDefinitions="Auto,*">
            <Border Grid.Row="0" Padding="10,8" CornerRadius="6,6,0,0" BorderBrush="Gray" BorderThickness="1">
                <Grid ColumnDefinitions="1.4*,1.1*,1.4*,1.7*,1.7*,2.3*,Auto" ColumnSpacing="8">
                    <TextBlock FontWeight="SemiBold" Text="ModId" />
                    <TextBlock Grid.Column="1" FontWeight="SemiBold" Text="版本" />
                    <TextBlock Grid.Column="2" FontWeight="SemiBold" Text="状态" />
                    <TextBlock Grid.Column="3" FontWeight="SemiBold" Text="依赖" />
                    <TextBlock Grid.Column="4" FontWeight="SemiBold" Text="依赖检查" />
                    <TextBlock Grid.Column="5" FontWeight="SemiBold" Text="路径" />
                    <TextBlock Grid.Column="6" HorizontalAlignment="Center" FontWeight="SemiBold" Text="操作" />
                </Grid>
            </Border>

            <Border Grid.Row="1" Padding="0,8,0,0" CornerRadius="0,0,6,6" BorderBrush="Gray" BorderThickness="1">
                <Grid>
                    <ScrollViewer IsVisible="{Binding HasMods}">
                        <ItemsControl ItemsSource="{Binding Mods}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ModItemViewModel">
                                    <Border Margin="8,0,8,8" Padding="10,8" CornerRadius="6" BorderBrush="#555555" BorderThickness="1">
                                        <Grid ColumnDefinitions="1.4*,1.1*,1.4*,1.7*,1.7*,2.3*,Auto" ColumnSpacing="8">
                                            <TextBlock VerticalAlignment="Center" Text="{Binding ModId}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{Binding Version}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="{Binding Status}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="{Binding DependenciesText}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="4" VerticalAlignment="Center" Text="{Binding IssuesText}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="5" VerticalAlignment="Center" Text="{Binding FilePath}" TextTrimming="CharacterEllipsis" />
                                            <Button
                                                Grid.Column="6"
                                                Width="72"
                                                Command="{Binding DataContext.ToggleEnabledCommand, ElementName=ModRoot}"
                                                CommandParameter="{Binding}"
                                                Content="切换"
                                                />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="16"
                        FontWeight="SemiBold"
                        IsVisible="{Binding HasNoMods}"
                        Text="当前档案暂无模组"
                        />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
