<UserControl
    x:Class="VSSL.Ui.Views.ModView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:VSSL.Ui.ViewModels"
    x:Name="ModRoot"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="vm:ModViewModel"
    mc:Ignorable="d"
    >
    <Design.DataContext>
        <vm:ModViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,Auto,*" RowSpacing="10">
        <Grid Grid.Row="0" Margin="12,0,12,0" ColumnDefinitions="2.1*,2.8*,Auto,Auto,Auto,Auto" ColumnSpacing="8">
            <ComboBox Grid.Column="0" ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <TextBox
                Grid.Column="1"
                Text="{Binding ModZipPath, UpdateSourceTrigger=PropertyChanged}"
                Watermark="{Binding [ModZipPathWatermark]}"
                />

            <Button Grid.Column="2" Command="{Binding BrowseModZipCommand}" Content="{Binding [CommonBrowseButtonText]}" />
            <Button Grid.Column="3" Command="{Binding ImportByPathCommand}" Content="{Binding [CommonImportButtonText]}" />
            <Button Grid.Column="4" Command="{Binding DeleteSelectedCommand}" Content="{Binding [CommonDeleteButtonText]}" />
            <Button Grid.Column="5" Command="{Binding RefreshCommand}" Content="{Binding [CommonRefreshButtonText]}" />
        </Grid>

        <TextBlock Grid.Row="1" Text="{Binding StatusMessage}" TextWrapping="Wrap" />

        <Grid Grid.Row="2" RowDefinitions="Auto,*">
            <Border Grid.Row="0" Padding="10,8" CornerRadius="6,6,0,0" BorderBrush="Gray" BorderThickness="1">
                <Grid ColumnDefinitions="52,1.4*,1.1*,1.4*,1.7*,1.7*,2.3*,Auto" ColumnSpacing="8">
                    <CheckBox IsChecked="{Binding SelectAll}" />
                    <TextBlock Grid.Column="1" FontWeight="SemiBold" Text="{Binding [ModHeaderModId]}" />
                    <TextBlock Grid.Column="2" FontWeight="SemiBold" Text="{Binding [ModHeaderVersion]}" />
                    <TextBlock Grid.Column="3" FontWeight="SemiBold" Text="{Binding [ModHeaderStatus]}" />
                    <TextBlock Grid.Column="4" FontWeight="SemiBold" Text="{Binding [ModHeaderDependencies]}" />
                    <TextBlock Grid.Column="5" FontWeight="SemiBold" Text="{Binding [ModHeaderDependencyCheck]}" />
                    <TextBlock Grid.Column="6" FontWeight="SemiBold" Text="{Binding [ModHeaderPath]}" />
                    <TextBlock Grid.Column="7" HorizontalAlignment="Center" FontWeight="SemiBold" Text="{Binding [ModHeaderAction]}" />
                </Grid>
            </Border>

            <Border Grid.Row="1" Padding="0,8,0,0" CornerRadius="0,0,6,6" BorderBrush="Gray" BorderThickness="1">
                <Grid>
                    <ScrollViewer IsVisible="{Binding HasMods}">
                        <ItemsControl ItemsSource="{Binding Mods}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ModItemViewModel">
                                    <Grid Margin="8,0,8,8" ColumnDefinitions="52,1.4*,1.1*,1.4*,1.7*,1.7*,2.3*,Auto" ColumnSpacing="8">
                                        <CheckBox IsChecked="{Binding IsSelected}" />
                                        <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{Binding ModId}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="{Binding Version}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="{Binding Status}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="4" VerticalAlignment="Center" Text="{Binding DependenciesText}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="5" VerticalAlignment="Center" Text="{Binding IssuesText}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="6" VerticalAlignment="Center" Text="{Binding FilePath}" TextTrimming="CharacterEllipsis" />
                                        <Button
                                            Grid.Column="7"
                                            Command="{Binding DataContext.ToggleEnabledCommand, ElementName=ModRoot}"
                                            CommandParameter="{Binding}"
                                            Content="{Binding DataContext[ModToggleButtonText], ElementName=ModRoot}"
                                            />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="16"
                        FontWeight="SemiBold"
                        IsVisible="{Binding HasNoMods}"
                        Text="{Binding [ModNoModsText]}"
                        />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
