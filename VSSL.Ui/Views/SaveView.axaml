<UserControl
    x:Class="VSSL.Ui.Views.SaveView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:VSSL.Ui.ViewModels"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="vm:SaveViewModel"
    mc:Ignorable="d"
    >
    <Design.DataContext>
        <vm:SaveViewModel />
    </Design.DataContext>

    <Border Padding="16" BorderBrush="Gray" BorderThickness="1" CornerRadius="8">
        <StackPanel Spacing="8">
            <TextBlock FontSize="24" FontWeight="Bold" Text="{Binding Title}" />
            <TextBlock Text="{Binding Description}" />
        </StackPanel>
    </Border>
</UserControl>

