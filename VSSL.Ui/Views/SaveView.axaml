<UserControl
    x:Class="VSSL.Ui.Views.SaveView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:VSSL.Ui.ViewModels"
    x:Name="SaveRoot"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="vm:SaveViewModel"
    mc:Ignorable="d"
    >
    <Design.DataContext>
        <vm:SaveViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,Auto,*" RowSpacing="10">
        <Grid Grid.Row="0" Margin="12,0,12,0" ColumnDefinitions="2.4*,2.2*,Auto,Auto,Auto" ColumnSpacing="8">
            <ComboBox Grid.Column="0" ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <TextBox
                Grid.Column="1"
                Text="{Binding NewSaveName, UpdateSourceTrigger=PropertyChanged}"
                Watermark="{Binding [SaveNameWatermark]}"
                />

            <Button Grid.Column="2" Command="{Binding CreateCommand}" Content="{Binding [CommonCreateButtonText]}" />
            <Button Grid.Column="3" Command="{Binding DeleteSelectedCommand}" Content="{Binding [CommonDeleteButtonText]}" />
            <Button Grid.Column="4" Command="{Binding RefreshCommand}" Content="{Binding [CommonRefreshButtonText]}" />
        </Grid>

        <StackPanel Grid.Row="1" Spacing="2">
            <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" />
            <TextBlock Text="{Binding CurrentProfileVersionText}" />
        </StackPanel>

        <Grid Grid.Row="2" RowDefinitions="Auto,*">
            <Border Grid.Row="0" Padding="10,8" CornerRadius="6,6,0,0" BorderBrush="Gray" BorderThickness="1">
                <Grid ColumnDefinitions="52,1.5*,2.8*,1.1*,1.6*,0.9*,Auto" ColumnSpacing="8">
                    <CheckBox IsChecked="{Binding SelectAll}" />
                    <TextBlock Grid.Column="1" FontWeight="SemiBold" Text="{Binding [SaveHeaderName]}" />
                    <TextBlock Grid.Column="2" FontWeight="SemiBold" Text="{Binding [SaveHeaderDirectory]}" />
                    <TextBlock Grid.Column="3" FontWeight="SemiBold" Text="{Binding [SaveHeaderSize]}" />
                    <TextBlock Grid.Column="4" FontWeight="SemiBold" Text="{Binding [SaveHeaderTime]}" />
                    <TextBlock Grid.Column="5" HorizontalAlignment="Center" FontWeight="SemiBold" Text="{Binding [SaveHeaderCurrent]}" />
                    <TextBlock Grid.Column="6" HorizontalAlignment="Center" FontWeight="SemiBold" Text="{Binding [SaveHeaderAction]}" />
                </Grid>
            </Border>

            <Border Grid.Row="1" Padding="0,8,0,0" CornerRadius="0,0,6,6" BorderBrush="Gray" BorderThickness="1">
                <Grid>
                    <ScrollViewer IsVisible="{Binding HasSaves}">
                        <ItemsControl ItemsSource="{Binding Saves}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:SaveFileItemViewModel">
                                    <Grid Margin="8,0,8,8" ColumnDefinitions="52,1.5*,2.8*,1.1*,1.6*,0.9*,Auto" ColumnSpacing="8">
                                        <CheckBox IsChecked="{Binding IsSelected}" />
                                        <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{Binding FileName}" TextTrimming="CharacterEllipsis" />
                                        <Button Grid.Column="2"
                                                HorizontalAlignment="Left"
                                                Command="{Binding DataContext.OpenSaveDirectoryCommand, ElementName=SaveRoot}"
                                                CommandParameter="{Binding}">
                                            <TextBlock Text="{Binding DirectoryPath}"
                                                       TextDecorations="Underline"
                                                       TextTrimming="CharacterEllipsis" />
                                        </Button>
                                        <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="{Binding SizeText}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="4" VerticalAlignment="Center" Text="{Binding LastWriteText}" TextTrimming="CharacterEllipsis" />
                                        <CheckBox Grid.Column="5" HorizontalAlignment="Center" IsChecked="{Binding IsActive}" IsEnabled="False" />
                                        <Button
                                            Grid.Column="6"
                                            Command="{Binding DataContext.SetActiveCommand, ElementName=SaveRoot}"
                                            CommandParameter="{Binding}"
                                            Content="{Binding DataContext[SaveSetActiveButtonText], ElementName=SaveRoot}"
                                            />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="16"
                        FontWeight="SemiBold"
                        IsVisible="{Binding HasNoSaves}"
                        Text="{Binding [SaveNoSavesText]}"
                        />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
