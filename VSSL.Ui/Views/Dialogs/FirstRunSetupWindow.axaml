<Window
    x:Class="VSSL.Ui.Views.Dialogs.FirstRunSetupWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="首次启动设置"
    Width="460"
    Height="260"
    MinWidth="460"
    MinHeight="260"
    MaxWidth="460"
    MaxHeight="260"
    CanResize="False"
    Icon="avares://VSSL.Ui/Assets/app-icon.ico"
    SystemDecorations="BorderOnly"
    WindowStartupLocation="CenterOwner">
    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="14" Margin="18">
        <StackPanel Grid.Row="0" Spacing="6">
            <TextBlock FontSize="19" FontWeight="SemiBold" Text="欢迎使用 VSSL" />
            <TextBlock Opacity="0.8" Text="请先选择默认主题和默认语言（仅首次显示）" />
        </StackPanel>

        <Grid Grid.Row="1" RowDefinitions="Auto,Auto" ColumnDefinitions="120,*" RowSpacing="12" ColumnSpacing="10">
            <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="默认主题" />
            <ComboBox x:Name="ThemeComboBox" Grid.Row="0" Grid.Column="1" />

            <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="默认语言" />
            <ComboBox x:Name="LanguageComboBox" Grid.Row="1" Grid.Column="1" />
        </Grid>

        <StackPanel Grid.Row="2" HorizontalAlignment="Right" Orientation="Horizontal" Spacing="8">
            <Button MinWidth="110" Click="OnConfirmClick">开始使用</Button>
        </StackPanel>
    </Grid>
</Window>

