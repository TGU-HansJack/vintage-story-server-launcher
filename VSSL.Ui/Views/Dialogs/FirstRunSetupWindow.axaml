<Window
    x:Class="VSSL.Ui.Views.Dialogs.FirstRunSetupWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="First Run Setup"
    Width="460"
    Height="260"
    MinWidth="460"
    MinHeight="260"
    MaxWidth="460"
    MaxHeight="260"
    CanResize="False"
    Icon="avares://VSSL.Ui/Assets/app-icon.ico"
    SystemDecorations="BorderOnly"
    WindowStartupLocation="CenterOwner">
    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="14" Margin="18">
        <StackPanel Grid.Row="0" Spacing="6">
            <TextBlock x:Name="TitleTextBlock" FontSize="19" FontWeight="SemiBold" Text="Welcome to VSSL" />
            <TextBlock x:Name="HintTextBlock" Opacity="0.8" Text="Please choose default theme and language (shown only once)." />
        </StackPanel>

        <Grid Grid.Row="1" RowDefinitions="Auto,Auto" ColumnDefinitions="120,*" RowSpacing="12" ColumnSpacing="10">
            <TextBlock x:Name="ThemeLabelTextBlock" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Default Theme" />
            <ComboBox x:Name="ThemeComboBox" Grid.Row="0" Grid.Column="1" />

            <TextBlock x:Name="LanguageLabelTextBlock" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Default Language" />
            <ComboBox x:Name="LanguageComboBox" Grid.Row="1" Grid.Column="1" />
        </Grid>

        <StackPanel Grid.Row="2" HorizontalAlignment="Right" Orientation="Horizontal" Spacing="8">
            <Button x:Name="ConfirmButton" Click="OnConfirmClick">Get Started</Button>
        </StackPanel>
    </Grid>
</Window>
