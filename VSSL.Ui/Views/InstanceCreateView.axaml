<UserControl
    x:Class="VSSL.Ui.Views.InstanceCreateView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:VSSL.Ui.ViewModels"
    x:Name="InstanceCreateRoot"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="vm:InstanceCreateViewModel"
    mc:Ignorable="d"
    >
    <Design.DataContext>
        <vm:InstanceCreateViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,Auto,*" RowSpacing="10">
        <!--  top controls: version / profile name / create / delete  -->
        <Grid Grid.Row="0" Margin="12,0,12,0" ColumnDefinitions="2.2*,2.4*,Auto,Auto,Auto" ColumnSpacing="8">
            <ComboBox
                Grid.Column="0"
                ItemsSource="{Binding InstalledVersions}"
                SelectedItem="{Binding SelectedVersion}"
                ToolTip.Tip="{Binding [InstanceCreateVersionTooltip]}"
                />

            <TextBox
                Grid.Column="1"
                Text="{Binding ProfileName, UpdateSourceTrigger=PropertyChanged}"
                Watermark="{Binding [InstanceCreateNameWatermark]}"
                />

            <Button Grid.Column="2" Command="{Binding CreateCommand}" Content="{Binding [CommonCreateButtonText]}" />
            <Button Grid.Column="3" Command="{Binding DeleteSelectedCommand}" Content="{Binding [CommonDeleteButtonText]}" />
            <Button Grid.Column="4" Command="{Binding RefreshCommand}" Content="{Binding [CommonRefreshButtonText]}" />
        </Grid>

        <!--  status line  -->
        <TextBlock
            Grid.Row="1"
            Text="{Binding StatusMessage}"
            TextWrapping="Wrap"
            />

        <!--  profiles list  -->
        <Grid Grid.Row="2" RowDefinitions="Auto,*">
            <Border Grid.Row="0" Padding="10,8" CornerRadius="6,6,0,0" BorderBrush="Gray" BorderThickness="1">
                <Grid ColumnDefinitions="52,1.4*,1.2*,4.2*,1.8*" ColumnSpacing="8">
                    <CheckBox IsChecked="{Binding SelectAll}" />
                    <TextBlock Grid.Column="1" FontWeight="SemiBold" Text="{Binding [InstanceCreateHeaderName]}" />
                    <TextBlock Grid.Column="2" FontWeight="SemiBold" Text="{Binding [InstanceCreateHeaderVersion]}" />
                    <TextBlock Grid.Column="3" FontWeight="SemiBold" Text="{Binding [InstanceCreateHeaderDirectory]}" />
                    <TextBlock Grid.Column="4" FontWeight="SemiBold" Text="{Binding [InstanceCreateHeaderTime]}" />
                </Grid>
            </Border>

            <Border Grid.Row="1" Padding="0,8,0,0" CornerRadius="0,0,6,6" BorderBrush="Gray" BorderThickness="1">
                <Grid>
                    <ScrollViewer IsVisible="{Binding HasProfiles}">
                        <ItemsControl ItemsSource="{Binding Profiles}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:InstanceProfileItemViewModel">
                                    <Grid Margin="8,0,8,8" ColumnDefinitions="52,1.4*,1.2*,4.2*,1.8*" ColumnSpacing="8">
                                        <CheckBox IsChecked="{Binding IsSelected}" />
                                        <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="{Binding Version}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="{Binding DirectoryPath}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="4" VerticalAlignment="Center" Text="{Binding CreatedAtText}" TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="16"
                        FontWeight="SemiBold"
                        IsVisible="{Binding HasNoProfiles}"
                        Text="{Binding [InstanceCreateNoProfilesText]}"
                        />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
