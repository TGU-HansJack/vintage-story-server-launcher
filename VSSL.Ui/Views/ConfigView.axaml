<UserControl
    x:Class="VSSL.Ui.Views.ConfigView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:VSSL.Ui.ViewModels"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="vm:ConfigViewModel"
    mc:Ignorable="d"
    >
    <Design.DataContext>
        <vm:ConfigViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,Auto,*" RowSpacing="10">
        <Grid Grid.Row="0" Margin="12,0,12,0" ColumnDefinitions="2.6*,Auto,Auto,Auto,Auto" ColumnSpacing="8">
            <ComboBox Grid.Column="0" ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <Button Grid.Column="1" Command="{Binding RefreshCommand}" Content="{Binding [CommonRefreshButtonText]}" />
            <Button Grid.Column="2" Command="{Binding ImportServerConfigCommand}" Content="{Binding [CommonImportButtonText]}" />
            <Button Grid.Column="3" Command="{Binding SaveCommand}" Content="{Binding [CommonSaveButtonText]}" />
            <Button Grid.Column="4" Command="{Binding EditAdvancedJsonCommand}" Content="{Binding [ConfigAdvancedJsonButtonText]}" />
        </Grid>

        <TextBlock Grid.Row="1" Text="{Binding StatusMessage}" TextWrapping="Wrap" />

        <Grid Grid.Row="2">
            <ScrollViewer IsVisible="{Binding HasProfiles}">
                <StackPanel Spacing="10">
                    <Border Padding="12" CornerRadius="8" BorderBrush="Gray" BorderThickness="1">
                        <StackPanel Spacing="10">
                            <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding [ConfigServerSectionTitle]}" />
                            <Grid ColumnDefinitions="Auto,2*,Auto,2*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="8">
                                <TextBlock VerticalAlignment="Center" Text="{Binding [ConfigServerNameLabel]}" />
                                <TextBox Grid.Column="1" Text="{Binding ServerName, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="{Binding [ConfigIpLabel]}" />
                                <TextBox Grid.Column="3" Text="{Binding Ip, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="1" VerticalAlignment="Center" Text="{Binding [ConfigPortLabel]}" />
                                <NumericUpDown Grid.Row="1" Grid.Column="1" Minimum="1" Maximum="65535" Value="{Binding Port}" />
                                <TextBlock Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" Text="{Binding [ConfigMaxPlayersLabel]}" />
                                <NumericUpDown Grid.Row="1" Grid.Column="3" Minimum="1" Maximum="200" Value="{Binding MaxClients}" />

                                <TextBlock Grid.Row="2" VerticalAlignment="Center" Text="{Binding [ConfigPasswordLabel]}" />
                                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Grid.Row="2" Grid.Column="2" VerticalAlignment="Center" Text="{Binding [ConfigWhitelistModeLabel]}" />
                                <NumericUpDown Grid.Row="2" Grid.Column="3" Minimum="0" Maximum="2" Value="{Binding WhitelistMode}" />

                                <CheckBox Grid.Row="3" Content="{Binding [ConfigAdvertiseServerLabel]}" IsChecked="{Binding AdvertiseServer}" />
                                <CheckBox Grid.Row="3" Grid.Column="1" Content="{Binding [ConfigAllowPvpLabel]}" IsChecked="{Binding AllowPvP}" />
                                <CheckBox Grid.Row="3" Grid.Column="2" Content="{Binding [ConfigAllowFireSpreadLabel]}" IsChecked="{Binding AllowFireSpread}" />
                                <CheckBox Grid.Row="3" Grid.Column="3" Content="{Binding [ConfigAllowFallingBlocksLabel]}" IsChecked="{Binding AllowFallingBlocks}" />

                                <TextBlock Grid.Row="4" VerticalAlignment="Center" Text="{Binding [ConfigServerLanguageLabel]}" />
                                <ComboBox Grid.Row="4" Grid.Column="1"
                                          ItemsSource="{Binding ServerLanguageOptions}"
                                          SelectedItem="{Binding ServerLanguage, Mode=TwoWay}" />
                                <TextBlock Grid.Row="4" Grid.Column="2" VerticalAlignment="Center" Text="{Binding [ConfigDefaultRoleCodeLabel]}" />
                                <TextBox Grid.Row="4" Grid.Column="3" Text="{Binding DefaultRoleCode, UpdateSourceTrigger=PropertyChanged}" />

                                <CheckBox Grid.Row="5" Content="{Binding [ConfigVerifyPlayerAuthLabel]}" IsChecked="{Binding VerifyPlayerAuth}" />
                                <TextBlock Grid.Row="5" Grid.Column="2" VerticalAlignment="Center" Text="{Binding [ConfigWelcomeMessageLabel]}" />
                                <TextBox Grid.Row="5" Grid.Column="3" Text="{Binding WelcomeMessage, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Padding="12" CornerRadius="8" BorderBrush="Gray" BorderThickness="1">
                        <StackPanel Spacing="10">
                            <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding [ConfigWorldSectionTitle]}" />
                            <Grid ColumnDefinitions="Auto,2*,Auto,2*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="8">
                                <TextBlock VerticalAlignment="Center" Text="{Binding [ConfigSeedLabel]}" />
                                <TextBox Grid.Column="1" Text="{Binding Seed, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="{Binding [ConfigWorldNameLabel]}" />
                                <TextBox Grid.Column="3" Text="{Binding WorldName, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="1" VerticalAlignment="Center" Text="{Binding [ConfigSaveFileLabel]}" />
                                <ComboBox Grid.Row="1" Grid.Column="1"
                                          ItemsSource="{Binding Saves}"
                                          SelectedItem="{Binding SelectedSave}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:SaveFileItemViewModel">
                                            <TextBlock Text="{Binding FileName}" TextTrimming="CharacterEllipsis" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <TextBlock Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" Text="{Binding [ConfigPlayStyleLabel]}" />
                                <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding PlayStyle, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="2" VerticalAlignment="Center" Text="{Binding [ConfigWorldTypeLabel]}" />
                                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding WorldType, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Grid.Row="2" Grid.Column="2" VerticalAlignment="Center" Text="{Binding [ConfigWorldHeightLabel]}" />
                                <NumericUpDown Grid.Row="2" Grid.Column="3" Minimum="64" Maximum="2048" Value="{Binding WorldHeight}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Padding="12" CornerRadius="8" BorderBrush="Gray" BorderThickness="1">
                        <StackPanel Spacing="10">
                            <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding [ConfigServerImagesSectionTitle]}" />

                            <StackPanel Spacing="4">
                                <TextBlock FontWeight="SemiBold" Text="{Binding [ConfigServerImagesRootLabel]}" />
                                <TextBlock Text="{Binding ImageRootPath}" TextWrapping="Wrap" Opacity="0.78" />
                            </StackPanel>

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                <Border Padding="10" CornerRadius="6" BorderBrush="Gray" BorderThickness="1">
                                    <StackPanel Spacing="8">
                                        <TextBlock FontWeight="SemiBold" Text="{Binding [ConfigServerImagesCoverTitle]}" />
                                        <TextBlock Text="{Binding CoverImageDisplayText}" TextWrapping="Wrap" />

                                        <StackPanel Spacing="6">
                                            <TextBlock Text="{Binding PendingCoverImportPath}" TextWrapping="Wrap" Opacity="0.78" />
                                            <WrapPanel Orientation="Horizontal" ItemHeight="32" ItemWidth="100">
                                                <Button Command="{Binding BrowseCoverImageCommand}" Content="{Binding [CommonBrowseButtonText]}" />
                                                <Button Command="{Binding ImportCoverImageCommand}" Content="{Binding [CommonImportButtonText]}" />
                                                <Button Command="{Binding PreviewCoverImageCommand}" Content="{Binding [ConfigServerImagesPreviewButtonText]}" />
                                                <Button Command="{Binding DeleteCoverImageCommand}" Content="{Binding [CommonDeleteButtonText]}" />
                                            </WrapPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Padding="10" CornerRadius="6" BorderBrush="Gray" BorderThickness="1">
                                    <StackPanel Spacing="8">
                                        <TextBlock FontWeight="SemiBold" Text="{Binding [ConfigServerImagesShowcaseTitle]}" />
                                        <TextBlock
                                            IsVisible="{Binding HasShowcaseImages}"
                                            Text="{Binding [ConfigServerImagesShowcaseHintText]}"
                                            Opacity="0.75"
                                            />
                                        <TextBlock
                                            IsVisible="{Binding HasNoShowcaseImages}"
                                            Text="{Binding [ConfigServerImagesNoShowcaseText]}"
                                            Opacity="0.75"
                                            />
                                        <ListBox MaxHeight="170"
                                                 ItemsSource="{Binding ShowcaseImages}"
                                                 SelectedItem="{Binding SelectedShowcaseImage}"
                                                 SelectionChanged="ShowcaseImages_OnSelectionChanged">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate x:DataType="vm:ConfigServerImageItemViewModel">
                                                    <StackPanel Spacing="2">
                                                        <TextBlock FontWeight="SemiBold" Text="{Binding FileName}" />
                                                        <TextBlock Opacity="0.72" Text="{Binding RelativePath}" TextWrapping="Wrap" />
                                                        <TextBlock Opacity="0.72" Text="{Binding SizeLabel}" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>

                                        <StackPanel Spacing="6">
                                            <TextBlock Text="{Binding PendingShowcaseImportPath}" TextWrapping="Wrap" Opacity="0.78" />
                                            <WrapPanel Orientation="Horizontal" ItemHeight="32" ItemWidth="100">
                                                <Button Command="{Binding BrowseShowcaseImageCommand}" Content="{Binding [CommonBrowseButtonText]}" />
                                                <Button Command="{Binding AddShowcaseImageCommand}" Content="{Binding [ConfigServerImagesAddButtonText]}" />
                                                <Button Command="{Binding ImportShowcaseFolderCommand}" Content="{Binding [CommonImportButtonText]}" />
                                                <Button Command="{Binding PreviewShowcaseImageCommand}" Content="{Binding [ConfigServerImagesPreviewButtonText]}" />
                                                <Button Command="{Binding DeleteShowcaseImageCommand}" Content="{Binding [CommonDeleteButtonText]}" />
                                            </WrapPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Padding="12" CornerRadius="8" BorderBrush="Gray" BorderThickness="1">
                        <StackPanel Spacing="10">
                            <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding [ConfigWorldRulesSectionTitle]}" />
                            <ItemsControl ItemsSource="{Binding WorldRules}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ConfigWorldRuleItemViewModel">
                                        <Grid Margin="0,0,0,8" ColumnDefinitions="1.5*,2.5*,*" ColumnSpacing="10">
                                            <TextBlock VerticalAlignment="Center" FontWeight="SemiBold" Text="{Binding Label}" />
                                            <StackPanel Grid.Column="1" Spacing="6">
                                                <CheckBox IsVisible="{Binding IsBoolean}" IsChecked="{Binding BoolValue, Mode=TwoWay}" />
                                                <ComboBox IsVisible="{Binding IsChoice}" ItemsSource="{Binding Choices}" SelectedItem="{Binding Value, Mode=TwoWay}" />
                                                <TextBox IsVisible="{Binding IsText}" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" VerticalAlignment="Center" Opacity="0.72" Text="{Binding Description}" TextWrapping="Wrap" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <TextBlock
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="16"
                FontWeight="SemiBold"
                IsVisible="{Binding HasNoProfiles}"
                Text="{Binding [ConfigNoProfileText]}"
                />
        </Grid>
    </Grid>
</UserControl>
