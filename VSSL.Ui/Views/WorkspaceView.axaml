<UserControl
    x:Class="VSSL.Ui.Views.WorkspaceView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:VSSL.Ui.ViewModels"
    x:Name="WorkspaceRoot"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="vm:WorkspaceViewModel"
    mc:Ignorable="d"
    >
    <Design.DataContext>
        <vm:WorkspaceViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="10">
        <Grid Grid.Row="0" Margin="12,0,12,0" ColumnDefinitions="Auto,160,Auto,220,Auto,*" ColumnSpacing="8">
            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding [WorkspaceQuickVersionLabel]}" />
            <ComboBox Grid.Column="1" Width="160" ItemsSource="{Binding InstalledVersions}" SelectedItem="{Binding SelectedInstalledVersion}" />

            <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="{Binding [WorkspaceQuickNameLabel]}" />
            <TextBox
                Grid.Column="3"
                Width="220"
                Text="{Binding QuickCreateProfileName, UpdateSourceTrigger=PropertyChanged}"
                Watermark="{Binding [WorkspaceQuickNameWatermark]}"
                />

            <Button
                Grid.Column="4"
                Command="{Binding CreateAndStartServerCommand}"
                Content="{Binding [WorkspaceQuickCreateAndStartButtonText]}"
                />

            <TextBlock
                Grid.Column="5"
                Margin="10,0,0,0"
                VerticalAlignment="Center"
                Foreground="#B00020"
                IsVisible="{Binding HasNoInstalledVersions}"
                Text="{Binding [WorkspaceQuickNoVersionText]}"
                TextTrimming="CharacterEllipsis"
                />
        </Grid>

        <Grid Grid.Row="1" Margin="12,0,12,0" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                <StackPanel.Styles>
                    <Style Selector="ComboBox">
                        <Setter Property="Height" Value="36" />
                        <Setter Property="VerticalAlignment" Value="Center" />
                    </Style>
                    <Style Selector="Button">
                        <Setter Property="Height" Value="36" />
                        <Setter Property="VerticalAlignment" Value="Center" />
                        <Setter Property="VerticalContentAlignment" Value="Center" />
                        <Setter Property="HorizontalContentAlignment" Value="Center" />
                    </Style>
                </StackPanel.Styles>
                <ComboBox Width="140" ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <ComboBox Width="180"
                          ItemsSource="{Binding Saves}"
                          SelectedItem="{Binding SelectedSave}"
                          IsEnabled="{Binding HasSaves}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:SaveFileItemViewModel">
                            <TextBlock Text="{Binding FileName}" TextTrimming="CharacterEllipsis" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Button Command="{Binding StartServerCommand}" Content="{Binding [WorkspaceStartServerButtonText]}" />
                <Button Command="{Binding StopServerCommand}" Content="{Binding [WorkspaceStopServerButtonText]}" />
            </StackPanel>

            <StackPanel
                Grid.Column="1"
                VerticalAlignment="Center"
                Spacing="2">
                <TextBlock Text="{Binding RuntimeStateText}" TextTrimming="CharacterEllipsis" />
                <TextBlock FontSize="12" Opacity="0.9" Text="{Binding StatusMessage}" TextTrimming="CharacterEllipsis" />
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                <CheckBox VerticalAlignment="Center" Content="{Binding [CommonFollowLabel]}" IsChecked="{Binding IsConsoleAutoFollow}" />
                <Button Command="{Binding RefreshProfilesCommand}" Content="{Binding [WorkspaceRefreshProfilesButtonText]}" />
                <Button Command="{Binding ClearConsoleCommand}" Content="{Binding [CommonClearButtonText]}" />
                <Button Command="{Binding ExportConsoleCommand}" Content="{Binding [CommonExportButtonText]}" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="2" RowDefinitions="Auto,*" RowSpacing="8">
            <Border
                Grid.Row="0"
                Margin="0,0,0,4"
                Padding="10,8"
                CornerRadius="4"
                BorderThickness="1"
                BorderBrush="Gray"
                IsVisible="{Binding IsStartupProgressVisible}"
                >
                <StackPanel>
                    <TextBlock Text="{Binding StartupProgressText}" />
                    <ProgressBar Minimum="0" Maximum="100" Height="10" Margin="0,6,0,0" Value="{Binding StartupProgress}" />
                </StackPanel>
            </Border>

            <Border Grid.Row="1" CornerRadius="6" BorderBrush="Gray" BorderThickness="1" Background="#000000" ClipToBounds="True">
                <Grid>
                    <ListBox
                        x:Name="ConsoleList"
                        ItemsSource="{Binding ConsoleLines}"
                        SelectionMode="{x:Static SelectionMode.Multiple}"
                        FontFamily="Consolas"
                        FontSize="12"
                        Foreground="#FFFFFF"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="6"
                        KeyDown="ConsoleList_OnKeyDown"
                        >
                        <ListBox.Styles>
                            <Style Selector="ListBoxItem">
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Style>
                            <Style Selector="ListBoxItem /template/ ContentPresenter">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Padding" Value="4,2" />
                                <Setter Property="Margin" Value="0,1,0,0" />
                            </Style>
                            <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                                <Setter Property="Background" Value="#404040" />
                            </Style>
                            <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                                <Setter Property="Background" Value="#0A64D8" />
                            </Style>
                        </ListBox.Styles>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding .}" TextWrapping="NoWrap" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Foreground="#BFBFBF"
                        IsVisible="{Binding HasNoConsoleLines}"
                        Text="{Binding [ConsoleNoOutputText]}"
                        />
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="3" ColumnDefinitions="*,220,Auto,Auto" ColumnSpacing="8">
            <TextBox Grid.Column="0" IsEnabled="{Binding CanSendCommands}" Text="{Binding ConsoleInput, UpdateSourceTrigger=PropertyChanged}" />
            <ComboBox
                Grid.Column="1"
                MinWidth="220"
                IsEnabled="{Binding CanSendCommands}"
                ItemsSource="{Binding QuickCommands}"
                SelectedItem="{Binding SelectedQuickCommand}"
                />
            <Button Grid.Column="2" Command="{Binding ManageQuickCommandsCommand}" Content="{Binding [WorkspaceQuickCommandsAddButtonText]}" />
            <Button Grid.Column="3" IsEnabled="{Binding CanSendCommands}" Command="{Binding SendConsoleCommandCommand}" Content="{Binding [WorkspaceSendCommandButtonText]}" />
        </Grid>
    </Grid>
</UserControl>
