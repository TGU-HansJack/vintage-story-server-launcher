<UserControl
    x:Class="VSSL.Ui.Views.HomeView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.Avalonia;assembly=LiveChartsCore.SkiaSharpView.Avalonia"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:VSSL.Ui.ViewModels"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="vm:HomeViewModel"
    mc:Ignorable="d"
    >
    <Design.DataContext>
        <vm:HomeViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,Auto,*" RowSpacing="12">
        <Border Grid.Row="0" Padding="12" CornerRadius="8" BorderBrush="Gray" BorderThickness="1">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                <Button Width="100" Command="{Binding RefreshMetricsCommand}" Content="刷新状态" />
                <TextBlock
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Text="实时状态概览：服务器内存、机器人内存、运行时间、在线玩家"
                    TextTrimming="CharacterEllipsis"
                    />
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="*,*,*,*" ColumnSpacing="10">
            <Border Padding="10" CornerRadius="8" BorderBrush="Gray" BorderThickness="1">
                <StackPanel Spacing="6">
                    <TextBlock FontWeight="SemiBold" Text="服务器" />
                    <TextBlock Text="{Binding ServerStateText}" />
                    <TextBlock Text="{Binding ServerMemoryText, StringFormat=内存：{0}}" />
                    <TextBlock Text="{Binding ServerUptimeText, StringFormat=运行：{0}}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Padding="10" CornerRadius="8" BorderBrush="Gray" BorderThickness="1">
                <StackPanel Spacing="6">
                    <TextBlock FontWeight="SemiBold" Text="机器人" />
                    <TextBlock Text="{Binding RobotStateText}" />
                    <TextBlock Text="{Binding RobotMemoryText, StringFormat=内存：{0}}" />
                    <TextBlock Text="{Binding RobotUptimeText, StringFormat=运行：{0}}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Padding="10" CornerRadius="8" BorderBrush="Gray" BorderThickness="1">
                <StackPanel Spacing="6">
                    <TextBlock FontWeight="SemiBold" Text="在线玩家" />
                    <TextBlock FontSize="24" FontWeight="Bold" Text="{Binding OnlinePlayersText}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="3" Padding="10" CornerRadius="8" BorderBrush="Gray" BorderThickness="1">
                <StackPanel Spacing="6">
                    <TextBlock FontWeight="SemiBold" Text="采样窗口" />
                    <TextBlock Text="最近 60 个采样点" />
                    <TextBlock Text="每秒自动更新" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="12">
            <Border Grid.Column="0" Padding="12" CornerRadius="8" BorderBrush="Gray" BorderThickness="1">
                <StackPanel Spacing="8">
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="内存趋势" />
                    <lvc:CartesianChart
                        Height="280"
                        LegendPosition="Top"
                        LegendTextPaint="{Binding LegendTextPaint}"
                        Series="{Binding MemorySeries}"
                        XAxes="{Binding MemoryXAxes}"
                        YAxes="{Binding MemoryYAxes}"
                        />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Padding="12" CornerRadius="8" BorderBrush="Gray" BorderThickness="1">
                <StackPanel Spacing="8">
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="玩家趋势" />
                    <lvc:CartesianChart
                        Height="280"
                        LegendPosition="Top"
                        LegendTextPaint="{Binding LegendTextPaint}"
                        Series="{Binding PlayerSeries}"
                        XAxes="{Binding PlayerXAxes}"
                        YAxes="{Binding PlayerYAxes}"
                        />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
