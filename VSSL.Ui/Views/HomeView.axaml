<UserControl
    x:Class="VSSL.Ui.Views.HomeView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:VSSL.Ui.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:VSSL.Ui.ViewModels"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="vm:HomeViewModel"
    mc:Ignorable="d"
    >
    <Design.DataContext>
        <vm:HomeViewModel />
    </Design.DataContext>

    <UserControl.Styles>
        <Style Selector="Border.home-info-card controls|SvgIcon.home-info-card-icon">
            <Setter Property="Width" Value="60" />
            <Setter Property="Height" Value="60" />
            <Setter Property="IconColor" Value="{DynamicResource HomeInfoCardGhostIconColor}" />
            <Setter Property="Opacity" Value="1" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Duration="0:0:0.16" Property="Width" />
                    <DoubleTransition Duration="0:0:0.16" Property="Height" />
                </Transitions>
            </Setter>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*" RowSpacing="12">
        <Grid Grid.Row="0" ColumnDefinitions="*,*,*,*" ColumnSpacing="10">
            <Border
                Classes="home-info-card"
                Padding="10"
                BorderBrush="Gray"
                BorderThickness="1"
                CornerRadius="8">
                <Grid ClipToBounds="True">
                    <StackPanel Spacing="6">
                        <TextBlock FontWeight="SemiBold" Text="{Binding [HomeServerCardTitle]}" />
                        <TextBlock Text="{Binding ServerStateText}" />
                        <TextBlock Text="{Binding ServerMemoryLineText}" />
                        <TextBlock Text="{Binding ServerUptimeLineText}" />
                    </StackPanel>
                    <controls:SvgIcon
                        Classes="home-info-card-icon"
                        Margin="0,0,-8,-8"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        IconName="ComputerRounded"
                        IsHitTestVisible="False"
                        >
                        <controls:SvgIcon.RenderTransform>
                            <RotateTransform Angle="-18" />
                        </controls:SvgIcon.RenderTransform>
                    </controls:SvgIcon>
                </Grid>
            </Border>

            <Border Grid.Column="1" Classes="home-info-card" Padding="10" CornerRadius="8" BorderBrush="Gray" BorderThickness="1">
                <Grid ClipToBounds="True">
                    <StackPanel Spacing="6">
                        <TextBlock FontWeight="SemiBold" Text="{Binding [HomeRobotCardTitle]}" />
                        <TextBlock Text="{Binding RobotStateText}" />
                        <TextBlock Text="{Binding RobotMemoryLineText}" />
                        <TextBlock Text="{Binding RobotUptimeLineText}" />
                    </StackPanel>
                    <controls:SvgIcon
                        Classes="home-info-card-icon"
                        Margin="0,0,-8,-8"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        IconName="FiRobot"
                        IsHitTestVisible="False"
                        >
                        <controls:SvgIcon.RenderTransform>
                            <RotateTransform Angle="-16" />
                        </controls:SvgIcon.RenderTransform>
                    </controls:SvgIcon>
                </Grid>
            </Border>

            <Border Grid.Column="2" Classes="home-info-card" Padding="10" CornerRadius="8" BorderBrush="Gray" BorderThickness="1">
                <Grid ClipToBounds="True">
                    <StackPanel Spacing="6">
                        <TextBlock FontWeight="SemiBold" Text="{Binding [HomeOnlinePlayersCardTitle]}" />
                        <TextBlock FontSize="24" FontWeight="Bold" Text="{Binding OnlinePlayersText}" />
                    </StackPanel>
                    <controls:SvgIcon
                        Classes="home-info-card-icon"
                        Margin="0,0,-8,-8"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        IconName="GroupsRounded"
                        IsHitTestVisible="False"
                        >
                        <controls:SvgIcon.RenderTransform>
                            <RotateTransform Angle="-18" />
                        </controls:SvgIcon.RenderTransform>
                    </controls:SvgIcon>
                </Grid>
            </Border>

            <Border Grid.Column="3" Classes="home-info-card" Padding="10" CornerRadius="8" BorderBrush="Gray" BorderThickness="1">
                <Grid ClipToBounds="True">
                    <StackPanel Spacing="6">
                        <TextBlock FontWeight="SemiBold" Text="{Binding [HomeSamplingWindowCardTitle]}" />
                        <TextBlock Text="{Binding [HomeSamplingWindowLine1]}" />
                        <TextBlock Text="{Binding [HomeSamplingWindowLine2]}" />
                    </StackPanel>
                    <controls:SvgIcon
                        Classes="home-info-card-icon"
                        Margin="0,0,-8,-8"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        IconName="TimerOutline"
                        IsHitTestVisible="False"
                        >
                        <controls:SvgIcon.RenderTransform>
                            <RotateTransform Angle="-18" />
                        </controls:SvgIcon.RenderTransform>
                    </controls:SvgIcon>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="1" VerticalAlignment="Top" ColumnDefinitions="*,*" ColumnSpacing="12">
            <Border Grid.Column="0" Padding="12" CornerRadius="8" BorderBrush="Gray" BorderThickness="1">
                <StackPanel Spacing="8">
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding [HomeMemoryTrendTitle]}" />
                    <controls:SimpleLineChart
                        Height="280"
                        IsDarkMode="{Binding IsDarkMode}"
                        PrimaryLegend="{Binding [HomeServerMemoryLegend]}"
                        PrimaryStroke="#5B9BD5"
                        PrimaryValues="{Binding ServerMemorySeries}"
                        SecondaryLegend="{Binding [HomeRobotMemoryLegend]}"
                        SecondaryStroke="#ED7D31"
                        SecondaryValues="{Binding RobotMemorySeries}"
                        XAxisLabel="{Binding [HomeSamplesAxisLabel]}"
                        YAxisLabel="MB"
                        YAxisValueFormat="0.0"
                        />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Padding="12" CornerRadius="8" BorderBrush="Gray" BorderThickness="1">
                <StackPanel Spacing="8">
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding [HomePlayerTrendTitle]}" />
                    <controls:SimpleLineChart
                        Height="280"
                        IsDarkMode="{Binding IsDarkMode}"
                        PrimaryLegend="{Binding [HomeOnlinePlayersLegend]}"
                        PrimaryStroke="#70AD47"
                        PrimaryValues="{Binding PlayerSeries}"
                        ShowZeroBasedYAxis="True"
                        XAxisLabel="{Binding [HomeSamplesAxisLabel]}"
                        YAxisLabel="{Binding [HomePlayersAxisLabel]}"
                        YAxisValueFormat="0"
                        />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
