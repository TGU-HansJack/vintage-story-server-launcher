<UserControl
    x:Class="VSSL.Ui.Views.RobotConsoleView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:VSSL.Ui.ViewModels"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="vm:RobotConsoleViewModel"
    mc:Ignorable="d"
    >
    <Design.DataContext>
        <vm:RobotConsoleViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,Auto,*" RowSpacing="10">
        <Grid Grid.Row="0" Margin="12,0,12,0" ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,*" ColumnSpacing="8">
            <Button Grid.Column="0" Command="{Binding StartCommand}" Content="{Binding [CommonStartButtonText]}" />
            <Button Grid.Column="1" Command="{Binding StopCommand}" Content="{Binding [CommonStopButtonText]}" />
            <Button Grid.Column="2" Command="{Binding RefreshCommand}" Content="{Binding [CommonRefreshButtonText]}" />
            <Button Grid.Column="3" Command="{Binding ClearCommand}" Content="{Binding [CommonClearButtonText]}" />
            <CheckBox Grid.Column="4" Content="{Binding [CommonFollowLabel]}" IsChecked="{Binding IsConsoleAutoFollow}" VerticalAlignment="Center" />
            <TextBlock Grid.Column="5" VerticalAlignment="Center" Text="{Binding RuntimeStateText}" TextTrimming="CharacterEllipsis" />
        </Grid>

        <TextBlock Grid.Row="1" Text="{Binding StatusMessage}" TextWrapping="Wrap" />

        <Border Grid.Row="2" Padding="12" CornerRadius="8" BorderBrush="Gray" BorderThickness="1" Background="#000000" ClipToBounds="True">
            <Grid>
                <ListBox
                    x:Name="RobotConsoleList"
                    ItemsSource="{Binding ConsoleLines}"
                    SelectionMode="{x:Static SelectionMode.Multiple}"
                    FontFamily="Consolas"
                    FontSize="12"
                    Foreground="#FFFFFF"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="6"
                    KeyDown="RobotConsoleList_OnKeyDown"
                    >
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Foreground" Value="#FFFFFF" />
                        </Style>
                        <Style Selector="ListBoxItem /template/ ContentPresenter">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Padding" Value="4,2" />
                            <Setter Property="Margin" Value="0,1,0,0" />
                        </Style>
                        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                            <Setter Property="Background" Value="#404040" />
                        </Style>
                        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                            <Setter Property="Background" Value="#0A64D8" />
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding .}" TextWrapping="NoWrap" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Foreground="#BFBFBF"
                    IsVisible="{Binding HasNoConsoleLines}"
                    Text="{Binding [ConsoleNoOutputText]}"
                    />
            </Grid>
        </Border>
    </Grid>
</UserControl>
