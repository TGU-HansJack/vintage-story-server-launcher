<UserControl
    x:Class="VSSL.Ui.Views.RobotConsoleView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:VSSL.Ui.ViewModels"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="vm:RobotConsoleViewModel"
    mc:Ignorable="d"
    >
    <Design.DataContext>
        <vm:RobotConsoleViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,Auto,*" RowSpacing="10">
        <Border Grid.Row="0" Padding="12" CornerRadius="8" BorderBrush="Gray" BorderThickness="1">
            <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,*" ColumnSpacing="8">
                <Button Grid.Column="0" Width="90" Command="{Binding StartCommand}" Content="启动" />
                <Button Grid.Column="1" Width="90" Command="{Binding StopCommand}" Content="停止" />
                <Button Grid.Column="2" Width="90" Command="{Binding RefreshCommand}" Content="刷新" />
                <Button Grid.Column="3" Width="90" Command="{Binding ClearCommand}" Content="清空" />
                <CheckBox Grid.Column="4" Content="追踪" IsChecked="{Binding IsConsoleAutoFollow}" VerticalAlignment="Center" />
                <TextBlock Grid.Column="5" VerticalAlignment="Center" Text="{Binding RuntimeStateText}" TextTrimming="CharacterEllipsis" />
            </Grid>
        </Border>

        <TextBlock Grid.Row="1" Text="{Binding StatusMessage}" TextWrapping="Wrap" />

        <Border Grid.Row="2" Padding="12" CornerRadius="8" BorderBrush="Gray" BorderThickness="1">
            <Grid>
                <ListBox
                    x:Name="RobotConsoleList"
                    ItemsSource="{Binding ConsoleLines}"
                    FontFamily="Consolas"
                    FontSize="12"
                    BorderThickness="0"
                    Padding="6"
                    />

                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="16"
                    FontWeight="SemiBold"
                    IsVisible="{Binding HasNoConsoleLines}"
                    Text="控制台暂无输出"
                    />
            </Grid>
        </Border>
    </Grid>
</UserControl>
