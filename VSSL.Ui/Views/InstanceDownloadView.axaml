<UserControl
    x:Class="VSSL.Ui.Views.InstanceDownloadView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:VSSL.Ui.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:VSSL.Ui.ViewModels"
    x:Name="InstanceDownloadRoot"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="vm:InstanceDownloadViewModel"
    mc:Ignorable="d"
    >
    <Design.DataContext>
        <vm:InstanceDownloadViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,Auto,*" RowSpacing="10">
        <!--  Top toolbar  -->
        <Grid Grid.Row="0" Margin="12,0,12,0" ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="8">
            <CheckBox
                Content="{Binding [InstanceDownloadShowDownloadedOnlyLabel]}"
                IsChecked="{Binding ShowDownloadedOnly}"
                VerticalAlignment="Center"
                />

            <Border
                Grid.Column="1"
                Height="34"
                CornerRadius="17"
                BorderBrush="Gray"
                BorderThickness="1"
                >
                <TextBox
                    Margin="10,0"
                    VerticalContentAlignment="Center"
                    Background="Transparent"
                    BorderThickness="0"
                    Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}"
                    Watermark="{Binding [InstanceDownloadSearchWatermark]}"
                    />
            </Border>

            <Button Grid.Column="2" Width="36" Height="34" Command="{Binding SearchCommand}" ToolTip.Tip="{Binding [CommonSearchTooltip]}">
                <controls:SvgIcon Width="18" Height="18" IconName="FiSearch" />
            </Button>

            <Button Grid.Column="3" Height="34" Command="{Binding ImportPackageCommand}" Content="{Binding [CommonImportButtonText]}" />
            <Button Grid.Column="4" Height="34" Command="{Binding RefreshCommand}" Content="{Binding [CommonRefreshButtonText]}" />
        </Grid>

        <!--  Status line  -->
        <TextBlock
            Grid.Row="1"
            Text="{Binding StatusMessage}"
            TextWrapping="Wrap"
            />

        <!--  List  -->
        <Grid Grid.Row="2" RowDefinitions="Auto,*">
            <Border Grid.Row="0" Padding="10,8" CornerRadius="6,6,0,0" BorderBrush="Gray" BorderThickness="1">
                <Grid ColumnDefinitions="1.3*,1.2*,0.9*,3.8*,Auto" ColumnSpacing="8">
                    <TextBlock FontWeight="SemiBold" Text="{Binding [InstanceDownloadHeaderVersion]}" />
                    <TextBlock Grid.Column="1" FontWeight="SemiBold" Text="{Binding [InstanceDownloadHeaderPlatform]}" />
                    <TextBlock Grid.Column="2" FontWeight="SemiBold" Text="{Binding [InstanceDownloadHeaderSize]}" />
                    <TextBlock Grid.Column="3" FontWeight="SemiBold" Text="{Binding [InstanceDownloadHeaderFilePath]}" />
                    <TextBlock Grid.Column="4" HorizontalAlignment="Center" FontWeight="SemiBold" Text="{Binding [InstanceDownloadHeaderAction]}" />
                </Grid>
            </Border>

            <Border Grid.Row="1" Padding="0,8,0,0" CornerRadius="0,0,6,6" BorderBrush="Gray" BorderThickness="1">
                <Grid>
                    <ScrollViewer IsVisible="{Binding HasData}">
                        <ItemsControl ItemsSource="{Binding Entries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:InstanceDownloadItemViewModel">
                                    <Grid Margin="8,0,8,8" ColumnDefinitions="1.3*,1.2*,0.9*,3.8*,Auto" ColumnSpacing="8">
                                        <TextBlock VerticalAlignment="Center" Text="{Binding Version}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{Binding Platform}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="{Binding FileSize}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="{Binding TargetFilePath}" TextTrimming="CharacterEllipsis" />

                                        <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                            <TextBlock VerticalAlignment="Center" Text="{Binding DownloadProgressText}" />
                                            <Button
                                                Width="32"
                                                Height="28"
                                                Command="{Binding DataContext.DownloadCommand, ElementName=InstanceDownloadRoot}"
                                                CommandParameter="{Binding}"
                                                IsEnabled="{Binding CanDownload}"
                                                ToolTip.Tip="{Binding FileName}"
                                                >
                                                <controls:SvgIcon Width="16" Height="16" IconName="FiDownload" />
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" IsVisible="{Binding HasNoData}">
                        <TextBlock HorizontalAlignment="Center" FontSize="16" FontWeight="SemiBold" Text="{Binding [InstanceDownloadNoContentText]}" />
                        <TextBlock HorizontalAlignment="Center" Text="{Binding StatusMessage}" TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
